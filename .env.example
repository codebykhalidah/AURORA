# =============================================================================
# Aurora Booking Standalone — Environment Variables
# Copy this file to `.env` and fill in real values before running locally or deploying.
# Never commit `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# PostgreSQL connection string used by Prisma.
# Examples:
#   Supabase: postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true
#   Neon:     postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
#   Local:    postgresql://postgres:postgres@localhost:5432/aurora_booking
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/aurora_booking?sslmode=require"

# Direct connection URL for migrations (optional; recommended with Supabase pooler).
# Use the non-pooled port (5432) when running `prisma migrate deploy`.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# -----------------------------------------------------------------------------
# Application URLs (required in production)
# Public URL of this deployment (no trailing slash).
# Used for metadata, CORS, and embed integrations.
# Examples:
#   https://booking.auroramaritime.com
#   https://aurora-booking-standalone.vercel.app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated list of origins allowed to call the booking API (CORS).
# Include your marketing site domain if the widget is embedded elsewhere.
# Example: https://auroramaritime.com,https://www.auroramaritime.com
ALLOWED_ORIGINS="http://localhost:3000"

# -----------------------------------------------------------------------------
# Security (required in production)
# Secret for Vercel Cron / manual calls to /api/cron/cleanup-holds
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRON_SECRET="replace-with-a-long-random-string"

# -----------------------------------------------------------------------------
# Runtime
# Set to "production" on Vercel automatically. Use "development" locally.
# NODE_ENV="development"

# Optional: log level for server-side logger (debug | info | warn | error)
# LOG_LEVEL="info"

# Optional: enable verbose Prisma query logs in development only
# PRISMA_LOG_QUERIES="false"
